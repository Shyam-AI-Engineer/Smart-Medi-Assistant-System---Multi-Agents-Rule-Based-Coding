# ============================================================================
# SMART MEDI ASSISTANT SYSTEM - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to git - it contains secrets!
# ============================================================================

# ============================================================================
# DATABASE (PostgreSQL Connection)
# ============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/smart_medi_dev
# Format: postgresql://username:password@host:port/database
# For production use: postgresql+asyncpg://user:pass@host:5432/db (async)

# ============================================================================
# REDIS (Caching & Session Storage)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
# Format: redis://host:port/database_number
# db 0 = development, db 1 = testing

# ============================================================================
# JWT & SECURITY
# ============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# OPENAI API (For AI Agents)
# ============================================================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: https://platform.openai.com/api-keys
# Models used: gpt-4, gpt-4-mini, whisper (for voice)

# ============================================================================
# FAISS (Local Vector Database for RAG)
# ============================================================================
FAISS_INDEX_PATH=./data/faiss_index
# Directory where FAISS stores medical document embeddings
# Will be created automatically if doesn't exist

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
ENVIRONMENT=development
# Options: development, staging, production

APP_NAME=Smart Medi Assistant
APP_VERSION=0.1.0
DEBUG=True
# Set to False in production!

# ============================================================================
# BACKEND SERVER
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=True
# Set BACKEND_RELOAD=False in production

# ============================================================================
# FRONTEND (CORS - allowed origins)
# ============================================================================
FRONTEND_URL=http://localhost:3000
# Full URL of frontend for CORS configuration

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
# Options: json, text

# ============================================================================
# SECURITY & COMPLIANCE
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# Allowed frontend origins (as JSON array)

ALLOW_REGISTRATION=True
# Set to False to disable new user registration (controlled)

# ============================================================================
# OPTIONAL: Pinecone (Cloud Vector DB - alternative to FAISS)
# ============================================================================
# PINECONE_API_KEY=xxx
# PINECONE_ENVIRONMENT=us-west4-gcp
# PINECONE_INDEX_NAME=medical-documents
